# Official PlayStation account credentials for sanctioned testing only.
# Keep this file local. .env is gitignored.
PSN_EMAIL=
PSN_PASSWORD=
PSN_TOTP_SECRET=

# Official login surface to automate with Playwright.
PSN_LOGIN_URL=
PSN_POST_LOGIN_URL=https://store.playstation.com/
PSN_STORAGE_STATE=artifacts/auth/playstation-storage-state.json

# Optional local paths for static analysis.
OFFICIAL_PC_APP_BUNDLE=

# Capture settings
CAPTURE_INTERFACE=en0
CAPTURE_DURATION=180
CAPTURE_FILTER=tcp port 443 or udp port 443 or port 53

# Playwright behavior
HEADLESS=false
SAVE_HTML=true
